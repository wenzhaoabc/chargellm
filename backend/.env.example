# ─────────────────────────────────────────────
# ChargeLLM Backend — 环境变量模板
# 生产环境请把真实凭据写入 backend/.env（已被 .gitignore 排除）
# ─────────────────────────────────────────────

# 应用 SQLite（对话/用户/邀请码/提示词等平台元数据）
DATABASE_URL=sqlite:////app/data/chargellm_demo.db
JWT_SECRET=change-me

# 初始管理员（首次启动时 bootstrap）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=xxxx

# SMS（mock 模式：不实发短信，只返回验证码便于联调）
SMS_MOCK_CODE=123456

# 邀请码默认配额
CHARGELLM_INVITE_DEFAULT_MAX_USES=20
CHARGELLM_INVITE_DEFAULT_PER_USER_QUOTA=10

# 物联平台：真实充电数据库（只读）。查询 SQL 见 app/services/charging_data_service.py
IOT_DB_URL=mysql://user:pwd@host:3306/database

# vLLM（OpenAI 兼容流式接口）
VLLM_MOCK=false
VLLM_BASE_URL=https://your-vllm-endpoint.example/v1
VLLM_MODEL=your-vlm-model
VLLM_API_KEY=replace-with-your-api-key

# CORS（允许的前端 origin）
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# 阿里云内容安全（TextModerationPlus）
# - service=query_security_check  → 输入同步阻断
# - service=response_security_check → 输出滚动窗口异步审核
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_CONTENT_SAFETY_ENDPOINT=green-cip.cn-shanghai.aliyuncs.com
ALIYUN_REGION_ID=cn-shanghai
# auto | aliyun | keyword | allow | block — 默认 auto：凭据齐全时用 aliyun，否则 keyword
# CHARGELLM_CONTENT_SAFETY_MODE=auto
# 可选：本地关键词模式下的敏感词表（逗号分隔）
# CHARGELLM_CONTENT_SAFETY_KEYWORDS=违法,暴力,色情,政治,自杀,毒品

# 前端（Vite 注入）
VITE_API_BASE_URL=/api
