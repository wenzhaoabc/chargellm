# CORS
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Aliyun content safety
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_CONTENT_SAFETY_ENDPOINT=
ALIYUN_GUARDRAIL_INPUT_SERVICE=
ALIYUN_GUARDRAIL_OUTPUT_SERVICE=response_security_check_hp

# Frontend
VITE_API_BASE_URL=/api
